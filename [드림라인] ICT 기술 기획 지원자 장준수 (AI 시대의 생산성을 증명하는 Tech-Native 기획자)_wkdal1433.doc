        }

        table {
            border-collapse: collapse;
            border-spacing: 0;
        }

        th, td {
            padding: 0;
            margin: 0;
        }

        address, caption, cite, code, dfn, em, strong, th, var {
            font-style: inherit;
            font-weight: inherit
        }

        p {
            margin: 0
        }

        strong {
            font-weight: bold
        }

        caption, legend, .hidden, .blind {
            overflow: hidden;
            position: absolute;
            top: 0;
            left: -1000%;
            z-index: -1;
            width: 1px;
            height: 1px;
            font-size: 0;
            line-height: 0
        }

        .print_wrap div, p, ul, td, input, a, span, em {
            font-style: normal;
            font-family: "Malgun Gothic", dotum, gulim, sans-serif;
            word-break: break-all;
            word-wrap: break-word;
        }
    </style>
